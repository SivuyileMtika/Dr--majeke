rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Appointments — dashboard reads directly via client SDK
    match /appointments/{apptId} {
      allow read: if true;   // doctor dashboard reads live
      allow write: if false; // only server (Admin SDK) writes
    }

    // Conversation state — server only
    match /patient_conversations/{phone} {
      allow read, write: if false;
    }

    // Time slots — server only
    match /time_slots/{slotId} {
      allow read: if true;
      allow write: if false;
    }

    // Services & medical aids — public read
    match /services/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /medical_aids/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else — deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
